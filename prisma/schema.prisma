// This file is required for Prisma Client to work with Next.js
// https://www.prisma.io/docs/guides/database/troubleshooting-orm/help-articles/nextjs-prisma-client-dev-practices

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  LEAGUE_ADMIN
  COACH
  CAPTAIN
  PLAYER
  REFEREE
}

enum SubscriptionTier {
  FREE
  STARTER
  GROWTH
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  UNPAID
}

enum SeasonStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}

enum GameStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  POSTPONED
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
}

enum TeamMemberRole {
  COACH
  CAPTAIN
  PLAYER
}

enum TeamMemberStatus {
  ACTIVE
  INACTIVE
}

enum PricingType {
  PER_PLAYER
  PER_TEAM
}

enum ChatRoomType {
  TEAM
  LEAGUE
  CUSTOM
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  firstName String?
  lastName  String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  role      UserRole @default(PLAYER)
  avatarUrl String?
  stripeCustomerId     String?
  subscriptionTier     String   @default("FREE")  // FREE, STARTER, GROWTH, PRO
  subscriptionStatus   String   @default("INACTIVE") // INACTIVE, ACTIVE, PAST_DUE, CANCELED
  stripeSubscriptionId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ownedLeagues         League[]            @relation("LeagueOwner")
  teamRegistrations    TeamRegistration[]  @relation("TeamRegUser")
  playerRegistrations  PlayerRegistration[] @relation("PlayerRegUser")
  coachedTeams      Team[]         @relation("TeamCoach")
  captainedTeams    Team[]         @relation("TeamCaptain")
  teamMemberships   TeamMember[]
  registrations     Registration[]
  chatMessages      ChatMessage[]
  chatMemberships   ChatMember[]
  refereeProfiles   Referee[]
  refereedGames     Game[]         @relation("GameReferee")

  @@index([email])
  @@index([role])
}

model League {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  ownerId            String
  logoUrl            String?
  sport              String
  description        String?
  settings           Json               @default("{}")
  subscriptionTier   SubscriptionTier   @default(FREE)
  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  stripeCustomerId        String?
  stripeConnectAccountId  String?  // Connected Stripe account for collecting payments
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relations
  owner         User           @relation("LeagueOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  divisions     Division[]
  seasons       Season[]
  teams         Team[]
  games         Game[]
  registrations Registration[]
  chatRooms     ChatRoom[]
  referees      Referee[]

  @@index([slug])
  @@index([ownerId])
  @@index([sport])
}

model Division {
  id          String   @id @default(cuid())
  leagueId    String
  name        String
  description String?
  order       Int      @default(0)
  price       Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  league          League           @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  seasonDivisions SeasonDivision[]
  teams           Team[]
  games           Game[]
  registrations   Registration[]

  @@index([leagueId])
  @@index([leagueId, order])
}

model Season {
  id                String       @id @default(cuid())
  leagueId          String
  name              String
  startDate         DateTime
  endDate           DateTime
  registrationOpen  Boolean      @default(false)
  paymentRequired   Boolean      @default(true)
  paymentDueDate    DateTime?
  status            SeasonStatus @default(UPCOMING)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relations
  league          League           @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  seasonDivisions SeasonDivision[]
  teams           Team[]
  games           Game[]
  registrations   Registration[]
  teamRegistrations TeamRegistration[]
  playerRegistrations PlayerRegistration[]
  seasonEnrollments SeasonEnrollment[]

  @@index([leagueId])
  @@index([leagueId, status])
}

model SeasonDivision {
  id          String      @id @default(cuid())
  seasonId    String
  divisionId  String
  price       Decimal     @db.Decimal(10, 2)
  pricingType PricingType @default(PER_PLAYER)
  maxTeams    Int?
  createdAt   DateTime    @default(now())

  // Relations
  season   Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  division Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)

  teamRegistrations TeamRegistration[]
  playerRegistrations PlayerRegistration[]
  seasonEnrollments SeasonEnrollment[]

  @@unique([seasonId, divisionId])
  @@index([seasonId])
  @@index([divisionId])
}

model Team {
  id         String   @id @default(cuid())
  leagueId   String
  divisionId String?
  seasonId   String?
  name       String
  logoUrl    String?
  coachId    String?
  captainId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  league        League         @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  division      Division?      @relation(fields: [divisionId], references: [id])
  season        Season?        @relation(fields: [seasonId], references: [id])
  coach         User?          @relation("TeamCoach", fields: [coachId], references: [id])
  captain       User?          @relation("TeamCaptain", fields: [captainId], references: [id])
  members       TeamMember[]
  homeGames     Game[]         @relation("HomeTeam")
  awayGames     Game[]         @relation("AwayTeam")
  registrations Registration[]
  chatRooms     ChatRoom[]
  seasonEnrollments SeasonEnrollment[]
  playerRegistrations PlayerRegistration[] @relation("PlayerRegTeam")

  @@index([leagueId])
  @@index([divisionId])
  @@index([seasonId])
}

model TeamMember {
  id       String           @id @default(cuid())
  teamId   String
  userId   String
  role     TeamMemberRole   @default(PLAYER)
  joinedAt DateTime         @default(now())
  status   TeamMemberStatus @default(ACTIVE)

  // Relations
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model Game {
  id          String     @id @default(cuid())
  leagueId    String
  seasonId    String
  divisionId  String?
  homeTeamId  String
  awayTeamId  String
  scheduledAt DateTime
  location    String?
  homeScore   Int?
  awayScore   Int?
  status      GameStatus @default(SCHEDULED)
  refereeId   String?
  notes       String?
  scheduleGroupId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  league   League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season   Season    @relation(fields: [seasonId], references: [id])
  division Division? @relation(fields: [divisionId], references: [id])
  homeTeam Team      @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team      @relation("AwayTeam", fields: [awayTeamId], references: [id])
  referee  User?     @relation("GameReferee", fields: [refereeId], references: [id])

  @@index([leagueId])
  @@index([seasonId])
  @@index([scheduledAt])
  @@index([status])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([scheduleGroupId])
}

model Registration {
  id                    String             @id @default(cuid())
  leagueId              String
  seasonId              String
  userId                String
  teamId                String?
  divisionId            String?
  status                RegistrationStatus @default(PENDING)
  paidAt                DateTime?
  amount                Decimal?           @db.Decimal(10, 2)
  stripePaymentIntentId String?
  notes                 String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  // Relations
  league   League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season   Season    @relation(fields: [seasonId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  team     Team?     @relation(fields: [teamId], references: [id])
  division Division? @relation(fields: [divisionId], references: [id])

  @@index([leagueId])
  @@index([seasonId])
  @@index([userId])
  @@index([status])
}

model ChatRoom {
  id          String       @id @default(cuid())
  leagueId    String
  name        String
  type        ChatRoomType @default(CUSTOM)
  teamId      String?
  autoAddRule Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  league   League        @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team     Team?         @relation(fields: [teamId], references: [id])
  messages ChatMessage[]
  members  ChatMember[]

  @@index([leagueId])
  @@index([teamId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  // Relations
  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id])

  @@index([roomId])
  @@index([roomId, createdAt])
}

model ChatMember {
  id       String   @id @default(cuid())
  roomId   String
  userId   String
  joinedAt DateTime @default(now())

  // Relations
  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

model Referee {
  id                 String  @id @default(cuid())
  userId             String
  leagueId           String
  certificationLevel String?
  available          Boolean @default(true)

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
  @@index([leagueId])
  @@index([available])
}

// LEGACY: TeamRegistration is kept for backward compatibility.
// New code should use Team + SeasonEnrollment instead.
model TeamRegistration {
  id               String   @id @default(cuid())
  seasonId         String
  seasonDivisionId String?
  teamName         String
  captainName      String
  captainEmail     String
  captainPhone     String?
  notes            String?
  userId                String?
  status                String   @default("PENDING") // PENDING, APPROVED, REJECTED
  paymentStatus         String?  // unpaid, paid, refunded
  paymentAmount         Decimal? @db.Decimal(10, 2)
  stripePaymentIntentId String?
  stripeCheckoutSessionId String?
  paidAt                DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  season         Season          @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonDivision SeasonDivision? @relation(fields: [seasonDivisionId], references: [id])
  user           User?           @relation("TeamRegUser", fields: [userId], references: [id])
  playerRegistrations PlayerRegistration[]

  @@index([seasonId])
  @@index([userId])
  @@index([status])
}

model PlayerRegistration {
  id               String   @id @default(cuid())
  seasonId         String
  seasonDivisionId String?
  teamRegistrationId String? // LEGACY: use teamId + seasonEnrollmentId instead
  teamId             String? // new: references Team directly
  seasonEnrollmentId String? // new: references SeasonEnrollment
  isCaptain          Boolean @default(false)
  userId           String?
  playerName       String
  playerEmail      String
  playerPhone      String?
  notes            String?
  paymentStatus         String?
  paymentAmount         Decimal? @db.Decimal(10, 2)
  stripePaymentIntentId String?
  stripeCheckoutSessionId String?
  paidAt                DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  season            Season            @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonDivision    SeasonDivision?   @relation(fields: [seasonDivisionId], references: [id])
  teamRegistration  TeamRegistration? @relation(fields: [teamRegistrationId], references: [id])
  team              Team?             @relation("PlayerRegTeam", fields: [teamId], references: [id])
  seasonEnrollment  SeasonEnrollment? @relation(fields: [seasonEnrollmentId], references: [id])
  user              User?             @relation("PlayerRegUser", fields: [userId], references: [id])

  @@index([seasonId])
  @@index([teamRegistrationId])
  @@index([teamId])
  @@index([seasonEnrollmentId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// NEW: Team registration architecture
// A SeasonEnrollment links a Team to a Season.
// Replaces the season-scoping that was baked into TeamRegistration.
// ─────────────────────────────────────────────

model SeasonEnrollment {
  id               String    @id @default(cuid())
  teamId           String
  seasonId         String
  seasonDivisionId String?
  status           String    @default("PENDING") // PENDING, APPROVED, REJECTED
  notes            String?

  // Payment fields
  paymentStatus           String?
  paymentAmount           Decimal? @db.Decimal(10, 2)
  stripePaymentIntentId   String?
  stripeCheckoutSessionId String?
  paidAt                  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team                Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  season              Season          @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonDivision      SeasonDivision? @relation(fields: [seasonDivisionId], references: [id])
  playerRegistrations PlayerRegistration[]

  @@unique([teamId, seasonId])
  @@index([seasonId])
  @@index([teamId])
}
